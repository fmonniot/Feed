# Template for app/keystore.properties (ticket #47).
#
# Copy this file to app/keystore.properties and fill in real values to enable
# release signing locally or in CI. app/keystore.properties is .gitignore'd —
# NEVER commit your real keystore credentials.
#
# See the "Release signing" section in CONTRIBUTING.md for how to generate a
# production keystore with keytool and where to store it.

# Absolute path (or path relative to app/) to the production .jks/.keystore file.
# Keep the keystore itself OUTSIDE the repo, e.g. in ~/.android/ or a team
# secrets manager.
storeFile=/path/to/your/release.keystore

# Password for the keystore itself.
storePassword=changeit

# Alias of the signing key inside the keystore.
keyAlias=feed-release

# Password for the signing key (may be the same as storePassword).
keyPassword=changeit
